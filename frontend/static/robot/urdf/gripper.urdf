<?xml version="1.0" ?>
<!-- Note: Do NOT add a 'world' link here - it causes crashes in MoveIt Setup Assistant on WSL.
     Instead, use a virtual_joint in the SRDF to attach the robot to the world frame. -->
<robot name="lebai_gripper">
  <!-- link list -->
  <link name="gripper_base_link">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_base.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_base.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_r_link1">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link1.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link1.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_r_link1_end_connection"/>
  <link name="gripper_r_link2">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link2.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link2.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_r_link_finger">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link_finger.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link_finger.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_r_link_finger_end_connection"/>
  <link name="gripper_l_link1">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link1.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link1.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_l_link1_end_connection"/>
  <link name="gripper_l_link2">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link2.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link2.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_l_link_finger">
    <visual>
      <geometry>
        <mesh filename="../meshes/gripper/visual/gripper_link_finger.dae"/>
      </geometry>
      <material name="white">
        <color rgba="0.86 0.85 0.81 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="../meshes/gripper/collision/gripper_link_finger.dae"/>
      </geometry>
    </collision>
  </link>
  <link name="gripper_l_link_finger_end_connection"/>
  <link name="gripper_tip_midpoint_arm"/>
  <link name="gripper_tip_midpoint_counterarm"/>
  <link name="gripper_tip"/>
  <!-- end of link list -->
  <!-- joint list -->
  <joint name="gripper_r_joint1" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_r_link1"/>
    <origin rpy="1.570796327 0.0 3.141592653589793" xyz="0.025 0.0 0.0856"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="0.0" upper="1.0471975511965976" velocity="1"/>
  </joint>
  <joint name="gripper_r_link1_end_connection_joint" type="fixed">
    <parent link="gripper_r_link1"/>
    <child link="gripper_r_link1_end_connection"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.053 0.0"/>
  </joint>
  <joint name="gripper_r_joint2" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_r_link2"/>
    <origin rpy="1.570796327 0 0" xyz="0.0115 0.0 0.1056"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.0471975511965976" upper="0.0" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="-1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_r_joint_finger" type="revolute">
    <parent link="gripper_r_link2"/>
    <child link="gripper_r_link_finger"/>
    <origin rpy="3.141592653589793 0 3.141592653589793" xyz="0.0 0.053 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.0471975511965976" upper="0.0" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="-1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_r_link_finger_end_connection_joint" type="revolute">
    <parent link="gripper_r_link_finger"/>
    <child link="gripper_r_link_finger_end_connection"/>
    <origin rpy="0.0 0.0 0.0" xyz="-0.0135 -0.02 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="0.0" upper="1.0471975511965976" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_l_joint1" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_l_link1"/>
    <origin rpy="1.570796327 0.0 0.0" xyz="-0.025 0.0 0.0856"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="0.0" upper="1.0471975511965976" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_l_link1_end_connection_joint" type="fixed">
    <parent link="gripper_l_link1"/>
    <child link="gripper_l_link1_end_connection"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.053 0.0"/>
  </joint>
  <joint name="gripper_l_joint2" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_l_link2"/>
    <origin rpy="1.570796327 0 3.141592653589793" xyz="-0.0115 0.0 0.1056"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.0471975511965976" upper="0.0" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="-1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_l_joint_finger" type="revolute">
    <parent link="gripper_l_link2"/>
    <child link="gripper_l_link_finger"/>
    <origin rpy="3.141592653589793 0 3.141592653589793" xyz="0.0 0.053 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.0471975511965976" upper="0.0" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="-1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_l_link_finger_end_connection_joint" type="revolute">
    <parent link="gripper_l_link_finger"/>
    <child link="gripper_l_link_finger_end_connection"/>
    <origin rpy="0.0 0.0 0.0" xyz="-0.0135 -0.02 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="0.0" upper="1.0471975511965976" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_tip_midpoint_arm_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="gripper_tip_midpoint_arm"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.1056"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.141592653589793" upper="3.141592653589793" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="1.0" offset="0.0"/>
  </joint>
  <joint name="gripper_tip_midpoint_counterarm_joint" type="revolute">
    <parent link="gripper_tip_midpoint_arm"/>
    <child link="gripper_tip_midpoint_counterarm"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0265"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.141592653589793" upper="3.141592653589793" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="-2.0" offset="0.0"/>
  </joint>
  <joint name="gripper_joint_tip" type="revolute">
    <parent link="gripper_tip_midpoint_counterarm"/>
    <child link="gripper_tip"/>
    <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0265"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.141592653589793" upper="3.141592653589793" velocity="1"/>
    <mimic joint="gripper_r_joint1" multiplier="1.0" offset="0.0"/>
